{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "VITE_AUTH_API_BASE_URL",
    "VITE_MARK_LIVE_API_BASE_URL",
    "VITE_APP_MARK_LIVE_NAME",
    "VITE_APP_MARK_LIVE_BASE_PATH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": true
    }
  }
}
